{
  "extends": "default",
  "meta": {
    "name": "demo-env-deny-precedence",
    "version": "1.0.0",
    "description": "Demo: deny_vars removes GITHUB_TOKEN even when GITHUB_* is allowed."
  },
  "environment": {
    "allow_vars": [
      "PATH",
      "GITHUB_*"
    ],
    "deny_vars": [
      "GITHUB_TOKEN"
    ]
  },
  "workdir": {
    "access": "none"
  },
  "filesystem": {
    "suppress_save_prompt": [
      "$HOME/.CFUserTextEncoding"
    ]
  },
  "command_policies": {
    "session_can_use": [
      "printenv"
    ],
    "commands": {
      "printenv": {
        "sandbox": {
          "environment": {
            "allow_vars": [
              "PATH",
              "GITHUB_*"
            ]
          }
        }
      }
    }
  }
}
