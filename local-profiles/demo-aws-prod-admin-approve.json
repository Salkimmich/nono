{
  "extends": "default",
  "meta": {
    "name": "demo-aws-prod-admin-approve",
    "version": "1.0.0",
    "description": "Demo: production AWS admin access uses a separate profile and approval prompts for high-risk operations."
  },
  "environment": {
    "deny_vars": [
      "AWS_ACCESS_KEY_ID",
      "AWS_SECRET_ACCESS_KEY",
      "AWS_SESSION_TOKEN",
      "AWS_PROFILE",
      "AWS_SHARED_CREDENTIALS_FILE",
      "AWS_CONFIG_FILE"
    ]
  },
  "workdir": {
    "access": "none"
  },
  "command_policies": {
    "session_can_use": [
      "aws"
    ],
    "commands": {
      "aws": {
        "sandbox": {
          "fs_read_file": [
            "/tmp/nono-demo/aws/credentials",
            "/tmp/nono-demo/aws/config"
          ],
          "network": {
            "tcp_connect_ports": [
              443
            ]
          },
          "environment": {
            "allow_vars": [
              "PATH",
              "HOME",
              "TMPDIR",
              "LANG",
              "LC_*",
              "SSL_CERT_FILE",
              "SSL_CERT_DIR",
              "AWS_CA_BUNDLE"
            ],
            "set_vars": {
              "AWS_CONFIG_FILE": "/tmp/nono-demo/aws/config",
              "AWS_PAGER": "",
              "AWS_PROFILE": "prod-admin",
              "AWS_SHARED_CREDENTIALS_FILE": "/tmp/nono-demo/aws/credentials"
            }
          }
        },
        "intercept": [
          {
            "args": [
              "cloudformation",
              "deploy"
            ],
            "action": {
              "type": "approve",
              "timeout_secs": 30
            }
          },
          {
            "args": [
              "ec2",
              "terminate-instances"
            ],
            "action": {
              "type": "approve",
              "timeout_secs": 30
            }
          },
          {
            "args": [
              "eks",
              "update-kubeconfig"
            ],
            "action": {
              "type": "approve",
              "timeout_secs": 30
            }
          },
          {
            "args": [
              "iam"
            ],
            "action": {
              "type": "approve",
              "timeout_secs": 30
            }
          },
          {
            "args": [
              "s3",
              "rm"
            ],
            "action": {
              "type": "approve",
              "timeout_secs": 30
            }
          }
        ]
      }
    }
  }
}
