{
  "extends": "default",
  "meta": {
    "name": "demo-npm-supply-chain",
    "version": "1.0.0",
    "description": "Demo: npm and node are allowed, but shell-backed lifecycle script execution is denied."
  },
  "environment": {
    "deny_vars": [
      "NPM_TOKEN",
      "NODE_AUTH_TOKEN",
      "GITHUB_TOKEN",
      "GH_TOKEN"
    ]
  },
  "workdir": {
    "access": "readwrite"
  },
  "filesystem": {
    "suppress_save_prompt": [
      "$HOME/.CFUserTextEncoding"
    ]
  },
  "command_policies": {
    "session_can_use": [
      "npm"
    ],
    "commands": {
      "npm": {
        "can_use": [
          "node"
        ],
        "sandbox": {
          "fs_read": [
            ".",
            "$HOME/.nvm/versions/node"
          ],
          "fs_write": [
            ".",
            "/tmp/nono-demo/npm-cache",
            "$TMPDIR"
          ],
          "network": {
            "allow_all": true
          },
          "environment": {
            "allow_vars": [
              "PATH",
              "HOME",
              "TMPDIR",
              "LANG",
              "LC_*",
              "npm_config_*",
              "NPM_CONFIG_*"
            ],
            "set_vars": {
              "NPM_CONFIG_AUDIT": "false",
              "NPM_CONFIG_CACHE": "/tmp/nono-demo/npm-cache",
              "NPM_CONFIG_FUND": "false",
              "NPM_CONFIG_UPDATE_NOTIFIER": "false"
            }
          }
        }
      },
      "node": {
        "from": {
          "npm": {
            "fs_read": [
              ".",
              "$HOME/.nvm/versions/node"
            ],
            "fs_write": [
              ".",
              "/tmp/nono-demo/npm-cache",
              "$TMPDIR"
            ],
            "network": {
              "allow_all": true
            },
            "environment": {
              "allow_vars": [
                "PATH",
                "HOME",
                "TMPDIR",
                "LANG",
                "LC_*",
                "NPM_CONFIG_*",
                "npm_config_*"
              ]
            }
          }
        }
      },
      "sh": {
        "from": {
          "npm": "deny",
          "node": "deny"
        }
      }
    }
  }
}
